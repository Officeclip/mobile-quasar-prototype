{
  "name": "mobile",
  "version": "1.0.11",
  "description": "Quasar Prototype of OfficeClip Mobile",
  "productName": "OfficeClip Suite",
  "author": "SK Dutta <skd@officeclip.com>",
  "private": true,
  "scripts": {
    "lint": "eslint --ext .js,.ts,.vue ./",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "backend": "json-server -p 4000 --w ./data/mock_data.json",
    "build": "quasar build",
    "test-android": "quasar dev -m capacitor -T android",
    "production-android": "quasar build -m capacitor -T android",
    "icons": "icongenie generate -i AppIcon.png --skip-trim"
  },
  "dependencies": {
    "@capacitor-mlkit/barcode-scanning": "^8.0.1",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/camera": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/filesystem": "^8.1.2",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@quasar/extras": "^1.17.0",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "axios": "^1.13.6",
    "cropperjs": "^1.5.13",
    "html5-qrcode": "^2.3.8",
    "pinia": "^3.0.4",
    "quasar": "^2.18.6",
    "rrule": "^2.8.1",
    "uuid": "^13.0.0",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@quasar/app-vite": "^2.4.1",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.27",
    "date-fns": "^4.1.0",
    "eslint": "^10.x",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "json-server": "^1.0.0-beta.12",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vue-eslint-parser": "^10.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">= 8.0.0",
    "yarn": ">= 1.21.1"
